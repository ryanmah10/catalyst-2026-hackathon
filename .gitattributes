# Auto detect text files and perform LF normalization
* text=auto

# Arduino/C++ source files
*.ino text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.c text eol=lf

# Web dashboard files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Binary files — tell Git not to diff these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bin binary
*.hex binary
*.elf binary
