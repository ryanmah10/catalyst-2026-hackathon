void handleCommand() {
  if (server.hasArg("v")) {
    currentCommand = server.arg("v");
    if (!autoMode) executeCommand();
  }
  server.send(200, "text/plain", "OK");
}

void handleSpeed() {
  if (server.hasArg("v")) {
    motorSpeed = constrain(server.arg("v").toInt(), 150, 255);
  }
  server.send(200, "text/plain", "OK");
}

void handleAuto() {
  autoMode = !autoMode;
  if (!autoMode) stopMotors();
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleSensors() {
  String json = "{";
  json += "\"temp\":"     + (isnan(lastTemp)     ? String("0") : String(lastTemp, 1))     + ",";
  json += "\"humidity\":" + (isnan(lastHumidity) ? String("0") : String(lastHumidity, 1)) + ",";
  json += "\"pressure\":" + String(lastPressure, 1) + ",";
  json += "\"distance\":" + String(lastDistance);
  json += "}";
  server.send(200, "application/json", json);
}

// ---------------- ULTRASONIC ----------------

long readDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  long duration = pulseIn(ECHO_PIN, HIGH, 10000);
  if (duration == 0) return 0;
  return duration * 0.034 / 2;
}

// ---------------- DISPLAY FUNCTIONS ----------------

void showTemp() {
  if (currentDisplay == 1) { restoreLCD(); return; }
  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("Temperature:");
  lcd.setCursor(0, 1);
  if (isnan(lastTemp)) lcd.print("Sensor Error!");
  else { lcd.print(lastTemp, 1); lcd.print(" C"); }
  displayActive = true; currentDisplay = 1;
}

void showHumidity() {
  if (currentDisplay == 2) { restoreLCD(); return; }
  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("Humidity:");
  lcd.setCursor(0, 1);
  if (isnan(lastHumidity)) lcd.print("Sensor Error!");
  else { lcd.print(lastHumidity, 1); lcd.print(" %"); }
  displayActive = true; currentDisplay = 2;
}

void showPressure() {
  if (currentDisplay == 3) { restoreLCD(); return; }
  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("Pressure:");
  lcd.setCursor(0, 1);
  lcd.print(lastPressure, 1); lcd.print(" hPa");
  displayActive = true; currentDisplay = 3;
}

// ---------------- SERIAL OUTPUT ----------------

void printAllToSerial() {
  Serial.println("--------------------");
  Serial.print("Temperature : ");
  if (isnan(lastTemp)) Serial.println("Error");
  else { Serial.print(lastTemp, 1); Serial.println(" C"); }
  Serial.print("Humidity    : ");
  if (isnan(lastHumidity)) Serial.println("Error");
  else { Serial.print(lastHumidity, 1); Serial.println(" %"); }
  Serial.print("Pressure    : "); Serial.print(lastPressure, 1); Serial.println(" hPa");
  Serial.print("Distance    : "); Serial.print(lastDistance); Serial.println(" cm");
  Serial.print("Auto Mode   : "); Serial.println(autoMode ? "ON" : "OFF");
  Serial.print("Command     : "); Serial.println(currentCommand);
  if (lastDistance > 0 && lastDistance < 20) Serial.println("!! OBSTACLE !!");
  Serial.println("--------------------");
}

// ---------------- BUTTON HANDLER ----------------

void checkButtons() {
  int pins[3] = {BTN_TEMP, BTN_HUMIDITY, BTN_PRESSURE};
  void (*actions[3])() = {showTemp, showHumidity, showPressure};
  for (int i = 0; i < 3; i++) {
    bool state = digitalRead(pins[i]);
    if (state == LOW && lastButtonState[i] == HIGH) {
      if ((millis() - lastDebounceTime[i]) > debounceDelay) {
        lastDebounceTime[i] = millis();
        actions[i]();
      }
    }
    lastButtonState[i] = state;
  }
}

// ---------------- SETUP ----------------

void setup() {
  Serial.begin(115200);
  delay(1000);

  Wire.begin(21, 22);
  dht.begin();

  pinMode(BTN_TEMP, INPUT_PULLUP);
  pinMode(BTN_HUMIDITY, INPUT_PULLUP);
  pinMode(BTN_PRESSURE, INPUT_PULLUP);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);

  analogWrite(ENA, 255);
  analogWrite(ENB, 255);
  stopMotors();

  lcd.init();
  lcd.backlight();

  if (!bmp.begin(0x76)) {
    if (!bmp.begin(0x77)) {
      Serial.println("BMP280 not found");
      lcd.clear(); lcd.setCursor(0, 0);
      lcd.print("BMP280 not found");
      while (true);
    }
  }

  lcd.clear(); lcd.setCursor(0, 0);
  lcd.print("Starting WiFi...");

  WiFi.softAP(ssid, password);
  IPAddress ip = WiFi.softAPIP();
  Serial.print("AP IP: "); Serial.println(ip);

  lcd.clear(); lcd.setCursor(0, 0);
  lcd.print("PlanetXRover");
  lcd.setCursor(0, 1); lcd.print(ip);

  server.on("/",        handleRoot);
  server.on("/cmd",     handleCommand);
  server.on("/speed",   handleSpeed);
  server.on("/auto",    handleAuto);
  server.on("/sensors", handleSensors);
  server.begin();
  Serial.println("Web server started");

  delay(3000);
  restoreLCD();
}

// ---------------- LOOP ----------------

void loop() {

  server.handleClient();

  if (millis() - lastDistanceUpdate >= distanceInterval) {
    lastDistanceUpdate = millis();

    lastTemp     = dht.readTemperature();
    lastHumidity = dht.readHumidity();
    lastPressure = bmp.readPressure() / 100.0F;
    lastDistance = readDistance();

    if (autoMode) {
      if (lastDistance > 0 && lastDistance < 20) {
        stopMotors();
        wasObstacle = true;
      } else {
        moveForward();
        if (wasObstacle) {
          wasObstacle = false;
          if (!displayActive) restoreLCD();
        }
      }
    }

    if (!displayActive) {
      lcd.setCursor(0, 1);
      lcd.print("Dist: ");
      lcd.print(lastDistance);
      lcd.print(" cm   ");
    }
  }

  if (millis() - lastSerialUpdate >= serialInterval) {
    lastSerialUpdate = millis();
    printAllToSerial();
  }

  checkButtons();
}
