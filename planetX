#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <DHT.h>
#include <Adafruit_BMP280.h>
#include <WiFi.h>
#include <WebServer.h>

// ---------------- PIN DEFINITIONS ----------------

#define DHTPIN 4
#define DHTTYPE DHT11

#define BTN_TEMP 15
#define BTN_HUMIDITY 2
#define BTN_PRESSURE 17

#define TRIG_PIN 5
#define ECHO_PIN 18

#define IN1 25
#define IN2 26
#define IN3 19
#define IN4 23
#define ENA 32
#define ENB 33

// ---------------- WiFi SETTINGS ----------------

const char* ssid     = "PlanetXRover";
const char* password = "rover1234";

// ---------------- OBJECTS ----------------

DHT dht(DHTPIN, DHTTYPE);
LiquidCrystal_I2C lcd(0x27, 16, 2);
Adafruit_BMP280 bmp;
WebServer server(80);

// ---------------- GLOBALS ----------------

unsigned long lastDebounceTime[3] = {0, 0, 0};
const int debounceDelay = 50;
unsigned long lastDistanceUpdate = 0;
const int distanceInterval = 1000;
unsigned long lastSerialUpdate = 0;
const int serialInterval = 2000;
bool wasObstacle = false;
bool displayActive = false;
int currentDisplay = 0;
long lastDistance = 0;

float lastTemp = 0;
float lastHumidity = 0;
float lastPressure = 0;

bool lastButtonState[3] = {HIGH, HIGH, HIGH};

int motorSpeed = 255;
bool autoMode = false;
String currentCommand = "stop";

// ---------------- HELPERS ----------------

void restoreLCD() {
  displayActive = false;
  currentDisplay = 0;
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Planet X Rover");
  lcd.setCursor(0, 1);
  lcd.print("Dist: ");
  lcd.print(lastDistance);
  lcd.print(" cm");
}

// ---------------- MOTOR FUNCTIONS ----------------

void moveForward() {
  analogWrite(ENA, motorSpeed);
  analogWrite(ENB, motorSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void moveBackward() {
  analogWrite(ENA, motorSpeed);
  analogWrite(ENB, motorSpeed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnLeft() {
  analogWrite(ENA, motorSpeed);
  analogWrite(ENB, motorSpeed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void turnRight() {
  analogWrite(ENA, motorSpeed);
  analogWrite(ENB, motorSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void stopMotors() {
  analogWrite(ENA, 0);
  analogWrite(ENB, 0);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

void executeCommand() {
  if      (currentCommand == "forward")  moveForward();
  else if (currentCommand == "backward") moveBackward();
  else if (currentCommand == "left")     turnLeft();
  else if (currentCommand == "right")    turnRight();
  else                                   stopMotors();
}

